<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select a crash scenario"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"
        android:gravity="center" />

    <Button
        android:id="@+id/btnCrashDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crash: Dialog on Destroyed Activity" />

    <Button
        android:id="@+id/btnCrashLateinit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crash: Access nulled lateinit" />

    <Button
        android:id="@+id/btnCrashFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crash: Fragment requireContext()" />

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp" />

</LinearLayout>